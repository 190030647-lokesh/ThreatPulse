<?xml version="1.0" encoding="UTF-8"?>
<Flow xmlns="http://soap.sforce.com/2006/04/metadata">
    <apiVersion>65.0</apiVersion>
    <assignments>
        <name>Set_Resolved_Date</name>
        <label>Set Resolved Date to Now</label>
        <locationX>176</locationX>
        <locationY>252</locationY>
        <assignmentItems>
            <assignToReference>$Record.Resolved_Date__c</assignToReference>
            <operator>Assign</operator>
            <value>
                <elementReference>$Flow.CurrentDateTime</elementReference>
            </value>
        </assignmentItems>
    </assignments>
    <description>When an Incident Status changes to Resolved or Closed and Resolved Date is blank, automatically stamps the Resolved Date.</description>
    <interviewLabel>Incident Set Resolved Date {!$Flow.CurrentDateTime}</interviewLabel>
    <label>Incident: Auto-Stamp Resolved Date</label>
    <processMetadataValues>
        <name>BuilderType</name>
        <value>
            <stringValue>LightningFlowBuilder</stringValue>
        </value>
    </processMetadataValues>
    <processMetadataValues>
        <name>CanvasMode</name>
        <value>
            <stringValue>AUTO_LAYOUT_CANVAS</stringValue>
        </value>
    </processMetadataValues>
    <processMetadataValues>
        <name>OriginBuilderType</name>
        <value>
            <stringValue>LightningFlowBuilder</stringValue>
        </value>
    </processMetadataValues>
    <processType>AutoLaunchedFlow</processType>
    <start>
        <locationX>50</locationX>
        <locationY>0</locationY>
        <connector>
            <targetReference>Set_Resolved_Date</targetReference>
        </connector>
        <filterFormula>(ISPICKVAL({!$Record.Status__c}, &apos;Resolved&apos;) || ISPICKVAL({!$Record.Status__c}, &apos;Closed&apos;)) &amp;&amp; ISBLANK({!$Record.Resolved_Date__c})</filterFormula>
        <object>Incident__c</object>
        <recordTriggerType>CreateAndUpdate</recordTriggerType>
        <triggerType>RecordBeforeSave</triggerType>
    </start>
    <status>Active</status>
</Flow>
